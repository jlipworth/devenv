#!/usr/bin/env bash
# Start the local macOS SSH notification relay if it is not already listening.
# Intended for OpenSSH LocalCommand; exits quickly and leaves a self-expiring
# foreground-style relay process behind only when needed.

set -euo pipefail

if [[ "$(uname -s)" != "Darwin" ]]; then
	exit 0
fi

socket_path="${AI_NOTIFY_RELAY_LOCAL_SOCKET:-$HOME/.cache/ai-notify/relay.sock}"
idle_timeout="${AI_NOTIFY_RELAY_IDLE_TIMEOUT:-28800}"
log_path="${AI_NOTIFY_RELAY_LOG:-$HOME/Library/Logs/ai-notify-relay.log}"

source_path="${BASH_SOURCE[0]}"
while [[ -L "$source_path" ]]; do
	source_dir="$(cd -- "$(dirname -- "$source_path")" && pwd)"
	source_path="$(/bin/ls -ld -- "$source_path" | sed 's/^.* -> //')"
	[[ "$source_path" != /* ]] && source_path="$source_dir/$source_path"
done
script_dir="$(cd -- "$(dirname -- "$source_path")" && pwd)"
relay="$script_dir/ai-notify-relay-local"

mkdir -p "$(dirname "$socket_path")" "$(dirname "$log_path")"

if [[ -S "$socket_path" ]] && printf '' | nc -U -w 1 "$socket_path" >/dev/null 2>&1; then
	exit 0
fi

rm -f "$socket_path"
AI_NOTIFY_RELAY_LOCAL_SOCKET="$socket_path" \
	AI_NOTIFY_DEBUG="${AI_NOTIFY_DEBUG:-0}" \
	nohup "$relay" --idle-timeout "$idle_timeout" >>"$log_path" 2>&1 &
