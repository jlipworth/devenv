#!/usr/bin/env bash

set -euo pipefail

if [[ "$(uname -s)" != "Darwin" ]]; then
  echo "ai-notify relay launch agent is macOS-only" >&2
  exit 1
fi

SOURCE_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE_PATH" ]]; do
  SOURCE_DIR="$(cd -- "$(dirname -- "$SOURCE_PATH")" && pwd)"
  SOURCE_PATH="$(readlink "$SOURCE_PATH")"
  [[ "$SOURCE_PATH" != /* ]] && SOURCE_PATH="$SOURCE_DIR/$SOURCE_PATH"
done
SCRIPT_DIR="$(cd -- "$(dirname -- "$SOURCE_PATH")" && pwd)"
relay="$SCRIPT_DIR/ai-notify-relay-local"
socket_path="${AI_NOTIFY_RELAY_LOCAL_SOCKET:-$HOME/.cache/ai-notify/relay.sock}"
plist="$HOME/Library/LaunchAgents/com.jlipworth.ai-notify-relay.plist"
label="com.jlipworth.ai-notify-relay"

mkdir -p "$(dirname "$socket_path")" "$HOME/Library/LaunchAgents"
chmod +x "$relay"

cat > "$plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>$label</string>
  <key>ProgramArguments</key>
  <array>
    <string>$relay</string>
    <string>--socket</string>
    <string>$socket_path</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>$HOME/Library/Logs/ai-notify-relay.log</string>
  <key>StandardErrorPath</key>
  <string>$HOME/Library/Logs/ai-notify-relay.err</string>
</dict>
</plist>
PLIST

uid="$(id -u)"
launchctl bootout "gui/$uid/$label" >/dev/null 2>&1 || true
launchctl bootstrap "gui/$uid" "$plist"
launchctl kickstart -k "gui/$uid/$label"

echo "Installed and started $label"
echo "Local relay socket: $socket_path"
