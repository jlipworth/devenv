#!/usr/bin/env python3
"""Local macOS relay for AI notifications forwarded from SSH sessions.

The remote side connects to a Unix socket that is usually exposed through
OpenSSH RemoteForward.  This process runs on the Mac, receives the already
parsed title/body, applies the same frontmost-terminal suppression policy, and
then invokes the repo-managed macOS notification backend.
"""

from __future__ import annotations

import argparse
import json
import os
import platform
import signal
import socket
import subprocess
import sys
from pathlib import Path
from typing import Any

DEFAULT_SOCKET = Path.home() / ".cache" / "ai-notify" / "relay.sock"
SCRIPT_DIR = Path(__file__).resolve().parent
MACOS_BACKEND = SCRIPT_DIR / "backends" / "macos-osascript.sh"


def debug(enabled: bool, message: str) -> None:
    if enabled:
        print(f"[ai-notify-relay] {message}", file=sys.stderr, flush=True)


def frontmost_app() -> str:
    if platform.system() != "Darwin":
        return ""
    try:
        result = subprocess.run(
            ["osascript", "-e", 'tell application "System Events" to name of first application process whose frontmost is true'],
            check=False,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            timeout=2,
        )
    except Exception:
        return ""
    return result.stdout.strip().lower()


def normalize_terminal(value: Any) -> str:
    terminal = str(value or "").strip().lower()
    if terminal.endswith(".exe"):
        terminal = terminal[:-4]
    if terminal in {"ghostty", "alacritty"}:
        return terminal
    return ""


def handle_message(raw: bytes, *, debug_enabled: bool) -> None:
    try:
        data = json.loads(raw.decode("utf-8"))
    except Exception as exc:
        debug(debug_enabled, f"invalid message ignored: {exc}")
        return

    title = str(data.get("title") or "Task finished")
    body = str(data.get("body") or "A background task completed.")
    terminal = normalize_terminal(data.get("terminal"))

    frontmost = frontmost_app()
    debug(debug_enabled, f"terminal={terminal or 'unknown'} frontmost_app={frontmost or 'unknown'}")
    if terminal in {"ghostty", "alacritty"} and frontmost == terminal:
        debug(debug_enabled, "suppressing notification because terminal is frontmost")
        return

    if platform.system() != "Darwin":
        debug(debug_enabled, "non-macOS relay host; no backend run")
        return
    if not MACOS_BACKEND.exists():
        debug(debug_enabled, f"backend missing: {MACOS_BACKEND}")
        return

    env = os.environ.copy()
    env.update(
        {
            "AI_NOTIFY_TITLE": title,
            "AI_NOTIFY_BODY": body,
            "AI_NOTIFY_TERMINAL_NAME": terminal,
            "AI_NOTIFY_DEBUG": "1" if debug_enabled else env.get("AI_NOTIFY_DEBUG", "0"),
        }
    )
    subprocess.run([str(MACOS_BACKEND)], env=env, check=False, stdout=subprocess.DEVNULL, stderr=None)


def serve(socket_path: Path, *, debug_enabled: bool) -> int:
    socket_path.parent.mkdir(parents=True, exist_ok=True)
    if socket_path.exists():
        socket_path.unlink()

    stop = False

    def request_stop(_signum: int, _frame: Any) -> None:
        nonlocal stop
        stop = True

    signal.signal(signal.SIGTERM, request_stop)
    signal.signal(signal.SIGINT, request_stop)

    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as server:
        server.bind(str(socket_path))
        os.chmod(socket_path, 0o600)
        server.listen(8)
        server.settimeout(1)
        debug(debug_enabled, f"listening on {socket_path}")
        while not stop:
            try:
                conn, _ = server.accept()
            except socket.timeout:
                continue
            with conn:
                chunks: list[bytes] = []
                while True:
                    chunk = conn.recv(8192)
                    if not chunk:
                        break
                    chunks.append(chunk)
                    if b"\n" in chunk:
                        break
                raw = b"".join(chunks).split(b"\n", 1)[0]
                if raw:
                    handle_message(raw, debug_enabled=debug_enabled)

    try:
        socket_path.unlink()
    except FileNotFoundError:
        pass
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(description="Run the local macOS AI notification relay socket.")
    parser.add_argument("--socket", default=str(DEFAULT_SOCKET), help=f"Unix socket path (default: {DEFAULT_SOCKET})")
    parser.add_argument("--debug", action="store_true", help="Log relay decisions to stderr.")
    args = parser.parse_args()
    return serve(Path(args.socket).expanduser(), debug_enabled=args.debug or os.environ.get("AI_NOTIFY_DEBUG") == "1")


if __name__ == "__main__":
    raise SystemExit(main())
