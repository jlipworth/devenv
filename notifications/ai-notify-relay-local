#!/usr/bin/env bash
# Foreground-only local macOS relay for SSH-forwarded AI notifications.
# This intentionally does not install a daemon or keep Python resident.

set -euo pipefail

socket_path="${AI_NOTIFY_RELAY_LOCAL_SOCKET:-$HOME/.cache/ai-notify/relay.sock}"
debug="${AI_NOTIFY_DEBUG:-0}"

usage() {
    cat <<USAGE
Usage: ai-notify-relay-local [--socket PATH]

Runs a foreground macOS Unix-socket relay for SSH AI notifications.
Stop it with Ctrl-C when you are done with the SSH work session.
USAGE
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --socket)
            socket_path="${2:?missing value for --socket}"
            shift 2
            ;;
        --debug)
            debug=1
            shift
            ;;
        -h | --help)
            usage
            exit 0
            ;;
        *)
            echo "unknown argument: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

log_debug() {
    if [[ "$debug" == "1" ]]; then
        printf '[ai-notify-relay] %s\n' "$*" >&2
    fi
}

if [[ "$(uname -s)" != "Darwin" ]]; then
    echo "ai-notify-relay-local is macOS-only" >&2
    exit 1
fi

if ! command -v nc > /dev/null 2>&1; then
    echo "ai-notify-relay-local requires nc" >&2
    exit 1
fi

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
backend="$script_dir/backends/macos-osascript.sh"

b64_decode() {
    if base64 --help 2>&1 | grep -q -- '-D'; then
        printf '%s' "$1" | base64 -D 2> /dev/null || true
    else
        printf '%s' "$1" | base64 -d 2> /dev/null || true
    fi
}

frontmost_app() {
    osascript 2> /dev/null <<'APPLESCRIPT' || true
tell application "System Events"
  name of first application process whose frontmost is true
end tell
APPLESCRIPT
}

handle_payload() {
    local payload="$1"
    local version terminal_b64 title_b64 body_b64 terminal title body frontmost

    version="$(printf '%s\n' "$payload" | sed -n '1p')"
    if [[ "$version" != "ai-notify-v1" ]]; then
        log_debug "invalid payload ignored"
        return 0
    fi

    terminal_b64="$(printf '%s\n' "$payload" | sed -n 's/^terminal=//p' | head -1)"
    title_b64="$(printf '%s\n' "$payload" | sed -n 's/^title=//p' | head -1)"
    body_b64="$(printf '%s\n' "$payload" | sed -n 's/^body=//p' | head -1)"

    terminal="$(b64_decode "$terminal_b64" | tr '[:upper:]' '[:lower:]')"
    terminal="${terminal%.exe}"
    title="$(b64_decode "$title_b64")"
    body="$(b64_decode "$body_b64")"
    [[ -n "$title" ]] || title="Task finished"
    [[ -n "$body" ]] || body="A background task completed."

    frontmost="$(frontmost_app | tr '[:upper:]' '[:lower:]')"
    log_debug "terminal=${terminal:-unknown} frontmost_app=${frontmost:-unknown}"
    if [[ ("$terminal" == "ghostty" || "$terminal" == "alacritty") && "$frontmost" == "$terminal" ]]; then
        log_debug "suppressing notification because terminal is frontmost"
        return 0
    fi

    AI_NOTIFY_TITLE="$title" \
        AI_NOTIFY_BODY="$body" \
        AI_NOTIFY_TERMINAL_NAME="$terminal" \
        AI_NOTIFY_DEBUG="$debug" \
        "$backend" || true
}

mkdir -p "$(dirname "$socket_path")"
rm -f "$socket_path"
trap 'rm -f "$socket_path"' EXIT INT TERM
log_debug "listening on $socket_path"

while true; do
    payload="$(nc -lU "$socket_path" || true)"
    [[ -n "$payload" ]] && handle_payload "$payload"
    rm -f "$socket_path"
done
